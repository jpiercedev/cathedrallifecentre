{
  "name": "cathedral-life-centre-nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "audit:links:local": "node scripts/run-browser-tests.mjs tests/local-links.spec.ts",
    "security:audit": "pnpm audit --audit-level=moderate",
    "validate": "pnpm lint && pnpm typecheck && pnpm test:browser && pnpm run security:audit"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@vimeo/player": "^2.30.4",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@sparticuz/chromium": "149.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
